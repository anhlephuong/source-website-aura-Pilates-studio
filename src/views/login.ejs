<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Đăng nhập — PilatesPhenikaa</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<link rel="stylesheet" href="/css/login.css">
</head>
<body>

<div id="page">

  <!-- ===== BÊN TRÁI ===== -->
  <div id="left-panel">

    <div class="left-content">

      <div class="left-eyebrow">PilatesPhenikaa</div>

      <h1 class="left-title">
        Quản lý phòng tập<br>
        Pilates của bạn
      </h1>

      <p class="left-sub">QUÀ TẶNG CỘT SỐNG</p>
      <p class="left-sub">Phần mềm quản lý phòng tập Pilates số 1 Việt Nam</p>
      <p class="left-sub">
        Hội viên, lớp học, huấn luyện viên, thanh toán và thiết bị —
        tất cả trong một nơi duy nhất.
      </p>

      <ul class="left-features">
        <li><i class="ti ti-circle-check"></i> Quản lý hội viên &amp; gói tập chuyên nghiệp</li>
        <li><i class="ti ti-circle-check"></i> Điểm danh, check-in chặt chẽ, báo cáo minh bạch</li>
        <li><i class="ti ti-circle-check"></i> Lịch lớp học và huấn luyện viên đồng bộ</li>
        <li><i class="ti ti-circle-check"></i> Dễ dàng mở rộng và quản lý đồng bộ chuỗi nhiều chi nhánh</li>
        <li><i class="ti ti-circle-check"></i> Tích hợp mượt mà thiết bị kiểm soát ra vào</li>
      </ul>

      <a href="#" class="left-cta">Đặt lịch demo miễn phí</a>
      <a href="#" class="left-cta">Nhận tư vấn nhanh, gọn và lẹ</a>

      <!-- Liên hệ -->
      <div class="left-contact">

        <h3>Liên hệ với chúng tôi</h3>

        <p>
          <i class="ti ti-phone"></i>
          1900 0009
        </p>

        <p>
          <i class="ti ti-mail"></i>
          phuonganhhd6789@gmail.com
        </p>

        <p>
          <i class="ti ti-map-pin"></i>
          Đại học Phenikaa, Hà Nội
        </p>

        <div class="social-icons">

          <a href="https://www.facebook.com/phuonganhkhongnguu"
             target="_blank"
             title="Facebook">
            <i class="ti ti-brand-facebook"></i>
          </a>

          <a href="https://www.tiktok.com/@anhlephuong236"
             target="_blank"
             title="TikTok">
            <i class="ti ti-brand-tiktok"></i>
          </a>

          <a href="https://www.instagram.com/phuonganhkhongnguu/"
             target="_blank"
             title="Instagram">
            <i class="ti ti-brand-instagram"></i>
          </a>

        </div>

      </div>
      <!-- Kết thúc left-contact -->

    </div>
    <!-- Kết thúc left-content -->

  </div>
  <!-- Kết thúc left-panel -->

  <!-- ===== BÊN PHẢI ===== -->

  <div id="right-panel">

    <!-- Banner -->
    <div class="top-banner">
      <div class="banner-brand">
        <div class="icon">🌿</div>
        <span class="name">PilatesPhenikaa</span>
      </div>
      <div class="banner-pill">Hướng dẫn truy cập tài khoản</div>
    </div>

    <!-- Card đăng nhập -->
    <div id="login-card">
      <div class="card-logo">
        <div class="icon">🌿</div>
        <span class="name">PilatesPhenikaa</span>
      </div>
      <div class="card-title">Hệ thống quản lý phòng tập</div>

      <form id="login-form" novalidate>
        <div id="form-error" class="form-error" hidden>
          <i class="ti ti-alert-circle"></i>
          <span id="form-error-text">Tài khoản hoặc mật khẩu không đúng.</span>
        </div>

        <div class="field-group">
          <label for="role">Chọn vai trò của bạn</label>
          <div class="select-wrap">
            <select id="role">
              <option value="admin">Quản lý phòng tập</option>
              <option value="trainer">Huấn luyện viên</option>
              <option value="member">Hội viên</option>
            </select>
            <i class="ti ti-chevron-down"></i>
          </div>
        </div>

        <div class="field-group">
          <label for="username">Tên đăng nhập (Email / SĐT) <span class="req">*</span></label>
          <div class="input-wrap">
            <input type="text" id="username" placeholder="ten@pilatesflow.vn" autocomplete="username" required>
          </div>
          <span class="field-hint" id="username-hint" hidden>Vui lòng nhập tên đăng nhập.</span>
        </div>

        <div class="field-group">
          <label for="password">Mật khẩu <span class="req">*</span></label>
          <div class="input-wrap">
            <input type="password" id="password" placeholder="Nhập mật khẩu" autocomplete="current-password" required>
            <button type="button" class="toggle-pw" id="toggle-pw" aria-label="Hiện mật khẩu">
              <i class="ti ti-eye"></i>
            </button>
          </div>
          <span class="field-hint" id="password-hint" hidden>Vui lòng nhập mật khẩu.</span>
        </div>

        <div class="options-row">
          <label class="checkbox-row">
            <input type="checkbox" id="remember">
            <span>Ghi nhớ đăng nhập</span>
          </label>
          <a href="#" class="link-sm" id="forgot-link">Quên mật khẩu?</a>
        </div>

        <button type="submit" class="btn-submit" id="submit-btn">
          <span class="btn-text">Đăng nhập</span>
          <span class="btn-spinner" hidden><i class="ti ti-loader-2"></i></span>
        </button>
      </form>

      <div class="card-footer-note">
        © 2026 PilatesPhenikaa. Mọi quyền được bảo lưu.<br>
        Hotline hỗ trợ: 1900 0009 — hỗ trợ kỹ thuật 24/7.
      </div>
      <div class="contact-icons">
        <a href="tel:19000009" title="Gọi điện"><i class="ti ti-phone"></i></a>
        <a href="#" title="Chat hỗ trợ"><i class="ti ti-message-circle"></i></a>
        <a href="mailto:support@pilatesflow.vn" title="Email"><i class="ti ti-mail"></i></a>
      </div>
    </div>

  </div>
</div>

<div id="toast" class="toast" hidden>
  <i class="ti ti-check"></i>
  <span id="toast-text">Đăng nhập thành công</span>
</div>

<script src="script.js"></script>
</body>
</html>